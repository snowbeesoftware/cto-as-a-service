#!/bin/bash

# CTO-as-a-service post-checkout hook
# Generated by cto-as-a-service
# 
# This hook runs after every git checkout, switch, and pull --rebase
# It analyzes any new commits using the local LLM

# Only run on branch checkouts (not file checkouts)
# $3 = 1 means branch checkout, $3 = 0 means file checkout
if [ "$3" = "1" ]; then
  # Find the cto-as-a-service binary
  # Assumes the hook is in .git/hooks/ and the bin is at ../../bin/cto-as-a-service
  SCRIPT_DIR="$(cd "$(dirname" && pwd "$0"))"
  BIN_PATH="$(dirname "$SCRIPT_DIR")/bin/cto-as-a-service"
  
  if [ -x "$BIN_PATH" ]; then
    "$BIN_PATH" analyze
  fi
fi
